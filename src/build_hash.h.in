#pragma once

// Generated by CMake from build_hash.h.in. Do not edit.
// Short git hash stamped into each recording so replay can refuse a file made
// by a different engine build. Resolved at configure time, so it can lag the
// working tree by a commit until the next cmake run. 0 means unstamped (no git
// available, or a recording made before stamping existed) and skips the check.
#define B2_BUILD_HASH 0x@BOX2D_BUILD_HASH@u
